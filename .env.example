# Copy to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.
#   cp .env.example .env.local

# Base URL the app is served from (OAuth redirects, email links, OG/sitemap).
APP_BASE_URL=http://localhost:3000

# Database file path (optional; defaults to woodchuckers.db).
# DATABASE_URL=woodchuckers.db

# Signing key for the stateless staff-session JWT (HS256). REQUIRED — /admin
# sign-in fails closed without it. Generate: openssl rand -hex 32
# Rotating it logs out every signed-in staff account.
SESSION_SECRET=

# Google SSO — https://console.cloud.google.com/apis/credentials
# Register BOTH Authorized redirect URIs on the same OAuth client:
#   $APP_BASE_URL/auth/google/callback       — staff portal login
#   $APP_BASE_URL/auth/lead/google/callback  — public lead-form sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: HMAC key for the public lead-identity cookie (the verified Google
# sign-in in front of the contract/lead form). Falls back to GOOGLE_CLIENT_SECRET
# when blank, so you only need to set this to rotate it independently.
LEAD_IDENTITY_SECRET=

# GitHub SSO — https://github.com/settings/developers
# Authorization callback URL: $APP_BASE_URL/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email for leads + employee invites — https://resend.com/api-keys
# MAIL_FROM must be a verified sender/domain (defaults to Resend's test sender).
RESEND_API_KEY=
MAIL_FROM=

# Online payments — https://dashboard.stripe.com/apikeys
# Powers /pay (customer enters amount → Stripe Checkout). Unset = payments fail
# closed (the /pay page still renders; checkout bounces back with a notice).
# Live: fly secrets set STRIPE_SECRET_KEY=sk_live_...  (-a woodchuckers-springs)
STRIPE_SECRET_KEY=

# CRM lead delivery (transactional outbox → signed webhook). Unset = no-op;
# the site never depends on the CRM to accept a lead. Same secret both apps.
CRM_WEBHOOK_URL=https://woodchuckers-crm.fly.dev/api/webhooks/leads
CRM_WEBHOOK_SECRET=

# CRM lead delivery (transactional outbox → signed webhook). Unset = no-op;
# the site never depends on the CRM to accept a lead. Same secret both apps.
CRM_WEBHOOK_URL=https://woodchuckers-crm.fly.dev/api/webhooks/leads
CRM_WEBHOOK_SECRET=
